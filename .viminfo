"3	CHAR	0
	function bash_vi_mode_cursor_change {
	    echo -ne "\e[2 q"
	    bind 'set keymap vi-insert' 
	    bind '"\e[A": history-search-backward'
	    bind '"\e[B": history-search-forward'
	    bind -m vi-insert '"\e[A": history-search-backward'
	    bind -m vi-insert '"\e[B": history-search-forward'
	    bind -m vi-insert '"\e": "\e[5 q"; vi-movement-mode'
	    bind -m vi-command '"i": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"I": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"a": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"A": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"c": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"C": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"r": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"R": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"s": "\e[6 q"; vi-insertion-mode'
	    bind -m vi-command '"S": "\e[6 q"; vi-insertion-mode'
	}
	
