"7	CHAR	0
	# Custom prompt for vi command mode
	function vi_mode_indicator {
	    echo -ne "\[\033[1;31m\]@\[\033[0m\] "
	}
	
	# Custom prompt for vi insert mode
	function insert_mode_indicator {
	    echo -ne "\[\033[1;32m\]|\[\033[0m\] "
	}
	
	function set_prompt {
	    case ${1:-$MODE} in
	        vi)
	            PS1="$(vi_mode_indicator)"
	            ;;
	        i*)
	            PS1="$(insert_mode_indicator)"
	            ;;
	        *)
	            PS1='\$ '
	            ;;
	    esac
	}
	
	# Enable vi mode and set prompt
	set -o vi
	PROMPT_COMMAND="set_prompt"
|3,0,7,0,27,0,1686937738,"# Custom prompt for vi command mode","function vi_mode_indicator {","    echo -ne \"\\[\\033[1;31m\\]@\\[\\033[0m\\] \"","}","","# Custom prompt for vi insert mode","function insert_mode_indicator {","    echo -ne \"\\[\\033[1;32m\\]|\\[\\033[0m\\] \"","}","","function set_prompt {","    case ${1:-$MODE} in","        vi)","            PS1=\"$(vi_mode_indicator)\"","            ;;","        i*)",>46
|<"            PS1=\"$(insert_mode_indicator)\"","            ;;","        *)","            PS1='\\$ '","            ;;","    esac","}","","# Enable vi mode and set prompt","set -o vi","PROMPT_COMMAND=\"set_prompt\""
